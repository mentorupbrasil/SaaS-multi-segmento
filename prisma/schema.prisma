// SaaS Multi-Segmento - schema Prisma
// Multi-tenant: banco compartilhado, isolamento por organizationId (row-level).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  ADMIN
  STAFF
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum FinancialType {
  INCOME
  EXPENSE
}

enum FinancialStatus {
  PENDING
  PAID
  OVERDUE
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  createdAt    DateTime     @default(now())
  memberships  Membership[]
}

// Tenant. Cada organizacao = um cliente isolado.
model Organization {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  segmentId          String // referencia ao template de segmento (codigo)
  config             Json               @default("{}") // overrides por tenant (termos, modulos extras)
  plan               String             @default("starter")
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  trialEndsAt        DateTime?
  createdAt          DateTime           @default(now())

  memberships      Membership[]
  customers        Customer[]
  services         Service[]
  appointments     Appointment[]
  financialEntries FinancialEntry[]
}

// Liga User <-> Organization com papel (RBAC).
model Membership {
  id             String  @id @default(cuid())
  userId         String
  organizationId String
  role           Role    @default(OWNER)
  title          String? // ex.: "Barbeiro", "Medico" - rotulo profissional

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments Appointment[] @relation("StaffAppointments")

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  phone          String?
  email          String?
  notes          String?
  customFields   Json     @default("{}") // campos especificos do segmento
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([organizationId])
}

model Service {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  price          Float    @default(0)
  durationMin    Int      @default(30)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([organizationId])
}

model Appointment {
  id             String            @id @default(cuid())
  organizationId String
  customerId     String
  serviceId      String?
  staffId        String?
  startAt        DateTime
  endAt          DateTime
  status         AppointmentStatus @default(SCHEDULED)
  notes          String?
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service      Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  staff        Membership?  @relation("StaffAppointments", fields: [staffId], references: [id], onDelete: SetNull)

  @@index([organizationId, startAt])
}

model FinancialEntry {
  id             String          @id @default(cuid())
  organizationId String
  type           FinancialType
  description    String
  amount         Float           @default(0)
  dueDate        DateTime?
  paidAt         DateTime?
  status         FinancialStatus @default(PENDING)
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}
