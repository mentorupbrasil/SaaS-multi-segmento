# ---------------------------------------------------------------------------
# Banco de dados (PostgreSQL / Neon)
# Use a connection string com pooling para a aplicacao.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# String direta (sem pooler) usada apenas para migrations, se necessario.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---------------------------------------------------------------------------
# NextAuth / Auth.js v5
# Gere um segredo com: npx auth secret   (ou)   openssl rand -base64 32
# ---------------------------------------------------------------------------
AUTH_SECRET="troque-por-um-segredo-aleatorio"

# Confia no host/porta do request (dev em qualquer porta)
AUTH_TRUST_HOST=true

# E-mails com acesso ao painel /admin (separados por virgula)
PLATFORM_ADMIN_EMAILS="admin@gestorpro.com"

# Em producao, defina a URL publica:
# AUTH_URL="https://seu-dominio.com"
# NEXT_PUBLIC_APP_URL="https://seu-dominio.com"
