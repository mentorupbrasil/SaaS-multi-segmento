# ---------------------------------------------------------------------------
# Banco de dados (PostgreSQL / Neon)
# Use a connection string com pooling para a aplicacao.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# String direta (sem pooler) usada apenas para migrations, se necessario.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---------------------------------------------------------------------------
# NextAuth / Auth.js v5
# Gere um segredo com: npx auth secret   (ou)   openssl rand -base64 32
# ---------------------------------------------------------------------------
AUTH_SECRET="troque-por-um-segredo-aleatorio"

# Confia no host/porta do request (dev em qualquer porta)
AUTH_TRUST_HOST=true

# E-mails com acesso ao painel /admin (separados por virgula)
PLATFORM_ADMIN_EMAILS="admin@gestorpro.com"

# Em producao, defina a URL publica:
# AUTH_URL="https://www.gestorpro.sbs"
# NEXT_PUBLIC_APP_URL="https://www.gestorpro.sbs"

# Contato publico (suporte, vendas, legal)
# NEXT_PUBLIC_WHATSAPP_NUMBER="5511999999999"

# ---------------------------------------------------------------------------
# E-mail (SMTP) — lembretes, convites e notificacoes
# ---------------------------------------------------------------------------
SMTP_HOST="smtp.exemplo.com"
SMTP_PORT="587"
SMTP_USER="usuario@smtp.exemplo.com"
SMTP_PASSWORD="senha-smtp"
SMTP_FROM="GestorPro <noreply@gestorpro.sbs>"
# Ou use Resend (recomendado na Vercel):
RESEND_API_KEY=""

# Uploads em producao (Vercel Blob)
BLOB_READ_WRITE_TOKEN=""

# Cron de automacoes (Vercel Cron + header Authorization: Bearer ...)
CRON_SECRET=""

# Rate limit APIs
RATE_LIMIT_API=60
RATE_LIMIT_API_WINDOW_MS=60000

# ---------------------------------------------------------------------------
# Feature flags (true/false ou 1/0)
# ---------------------------------------------------------------------------
FEATURE_IA=false
FEATURE_PORTAL=false
FEATURE_PUBLIC_BOOKING=true
FEATURE_WHATSAPP=true
FEATURE_SENTRY=false
FEATURE_ANALYTICS=false

# OpenAI (módulo IA — habilitar FEATURE_IA=true)
OPENAI_API_KEY=""

# Webhooks de integrações (/api/integrations/webhook/*)
INTEGRATION_WEBHOOK_SECRET=""

# ---------------------------------------------------------------------------
# Asaas (produção — cobrança real)
ASAAS_API_KEY=""
ASAAS_ENV="production"
ASAAS_WEBHOOK_TOKEN=""

# ---------------------------------------------------------------------------
# Rate limit (memoria local; em producao use Upstash Redis)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
RATE_LIMIT_LOGIN=10
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_SIGNUP=5
RATE_LIMIT_SIGNUP_WINDOW_MS=3600000

# ---------------------------------------------------------------------------
# OAuth (Google) — habilitado apenas se ambos estiverem definidos
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# Observabilidade e analytics
# ---------------------------------------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_GA_ID=""
